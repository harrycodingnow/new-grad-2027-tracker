# Copy to .env for local development. All variables are OPTIONAL.
# The monitor runs fully without any of these.

# --- GitHub issue notifications (set automatically inside GitHub Actions) ---
# GITHUB_TOKEN=ghp_xxx           # token with issues:write; Actions provides this
# GITHUB_REPOSITORY=owner/repo   # Actions provides this

# --- Optional Telegram notifications (disabled by default) ---
# TELEGRAM_BOT_TOKEN=123456:ABC-xxx
# TELEGRAM_CHAT_ID=123456789
